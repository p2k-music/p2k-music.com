# Build artifacts / downloads (regenerable — keep out of the backup)
*.zip

# OS / editor cruft
Thumbs.db
ehthumbs.db
.DS_Store
Desktop.ini
*.swp
*~

# Local tooling (safe to keep out of the backup)
.claude/settings.local.json

# Backend secrets + runtime state (NEVER commit these)
server/.env
server/data/

# The raw upload folder (real files now live in audio/)
Audio-Files/

# Full-res background source (the optimized background.jpg is what the site uses)
aromantic-asexual-4096x2304-11873.jpg

# NOTE: the audio/ folder is intentionally NOT ignored — the whole point of the
# backup is to save P2K's tracks. Make sure audio/ holds the REAL .mp3/.mp4 files
# (not the 1-byte preview placeholders) before running a backup you care about.
