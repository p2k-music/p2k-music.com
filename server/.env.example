# ============================================================
#  p2k-music.ca backend — configuration
#  Copy this file to  server/.env  and fill in real values.
#  server/.env is git-ignored. NEVER commit real secrets.
# ============================================================

# --- server ---
PORT=8123
# Set true only when the site is served over HTTPS (enables Secure cookies + HSTS)
BEHIND_TLS=false
# Set true only when running behind a trusted reverse proxy (honours X-Forwarded-For)
TRUST_PROXY=false

# --- admin accounts (two logins) ---
# Each admin logs in with email + password, then a one-time code emailed to them.
# Leave a password blank to have one generated + printed once on first run (then change it).
ADMIN1_EMAIL=tajallatajalla2@gmail.com
ADMIN1_PASS=
ADMIN2_EMAIL=aaron.styles9393@gmail.com
ADMIN2_PASS=

# --- 2FA one-time code ---
CODE_TTL_MIN=5
CODE_MAX_ATTEMPTS=5
# LOCAL DEV ONLY: show the code on-screen instead of emailing it — honoured only for
# localhost requests. Leave this UNSET in production so login FAILS CLOSED (a code can
# only be received via the real email inbox). Never set this on a public server.
# DEV_SHOW_CODE=1

# Account lockout: lock an admin after this many wrong passwords, for this many minutes.
LOCK_THRESHOLD=8
LOCK_MINUTES=15

# --- SMTP: sends the login code. REQUIRED in production (no SMTP = nobody can log in). ---
# Gmail: SMTP_USER = your gmail, SMTP_PASS = a Google "App Password" (not your normal password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- money ---
CURRENCY=CAD
SONG_PRICE=16
PAYOUT_EMAIL=p2key1@gmail.com
MIN_WITHDRAW=1.55
# Projected streaming royalty in $ per counted play-minute (default = legacy $1.55/3min)
LISTEN_RATE_PER_MIN=0.5167

# --- PayPal (leave BOTH blank for DEMO mode: payments/payouts simulated locally) ---
# From developer.paypal.com → your REST app. Use sandbox creds first.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# 'sandbox' (default) or 'production'
PAYPAL_ENV=sandbox
# For webhook verification (developer.paypal.com → Webhooks)
PAYPAL_WEBHOOK_ID=

# --- anti-fraud tuning (listen wallet) ---
TICK_MIN_INTERVAL_MS=55000
TICK_DAILY_CAP_VISITOR=600
TICK_DAILY_CAP_IP=1500
